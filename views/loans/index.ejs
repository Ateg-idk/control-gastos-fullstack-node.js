<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Centro de Préstamos - GastosMoni</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body>
    <div class="container" style="display: flex; min-height: 100vh;">
        <%- include('../partials/sidebar', { activePage: 'loans' }) %>

            <div id="loadingOverlay"
                style="display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(4px); z-index: 2000; align-items: center; justify-content: center; flex-direction: column; color: white;">
                <div class="spinner"
                    style="width: 40px; height: 40px; border: 4px solid rgba(255,255,255,0.1); border-top-color: white; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 1rem;">
                </div>
                <p style="font-weight: 700; letter-spacing: 0.05em;">ACTUALIZANDO ESTADO...</p>
            </div>

            <style>
                @keyframes spin {
                    to {
                        transform: rotate(360deg);
                    }
                }

                .row-completed {
                    opacity: 0.6;
                    background: #f8fafc !important;
                }

                /* Toast Notification */
                #toast {
                    position: fixed;
                    bottom: 2rem;
                    left: 50%;
                    transform: translateX(-50%) translateY(100px);
                    background: #0f172a;
                    color: white;
                    padding: 1rem 2rem;
                    border-radius: 1rem;
                    font-weight: 700;
                    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2);
                    z-index: 2000;
                    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
                    display: flex;
                    align-items: center;
                    gap: 0.75rem;
                }

                #toast.show {
                    transform: translateX(-50%) translateY(0);
                }
            </style>

            <div id="toast">
                <i class="fas fa-circle-check" style="color: var(--success);"></i>
                <span id="toastMessage">Estado actualizado</span>
            </div>

            <main class="main-content">
                <header class="top-nav animate-slide-up">
                    <div class="welcome-text">
                        <h1>Centro de Préstamos</h1>
                        <p>Gestión de activos y cuentas por cobrar externas.</p>
                    </div>
                    <div class="header-actions">
                        <button onclick="toggleModal('loanModal')" class="btn btn-primary"
                            style="padding: 1rem 1.5rem; border-radius: 1rem; box-shadow: 0 10px 15px -3px rgba(67, 56, 202, 0.25);">
                            <i class="fas fa-plus-circle"></i> Nuevo Préstamo
                        </button>
                    </div>
                </header>
                <div class="stats-grid animate-slide-up" style="display: grid; gap: 1.5rem; margin-bottom: 2rem;">
                    <% let externalLoans=loans.filter(l=> !l.from_budget);
                        let extTotal = externalLoans.reduce((sum, l)=> sum + parseFloat(l.amount), 0);
                        let extRecovered = externalLoans.reduce((sum, l) => sum + parseFloat(l.paid_amount || 0), 0);
                        let extPending = extTotal - extRecovered;

                        let budgetLoans = loans.filter(l => l.from_budget);
                        let budTotal = budgetLoans.reduce((sum, l)=> sum + parseFloat(l.amount), 0);
                        let budRecovered = budgetLoans.reduce((sum, l) => sum + parseFloat(l.paid_amount || 0), 0);
                        let budPending = budTotal - budRecovered;
                        %>
                        <!-- External Loans block -->
                        <div class="premium-card"
                            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1.5rem; align-items: center; border-left: 5px solid var(--primary);">
                            <div style="grid-column: 1 / -1;">
                                <h3
                                    style="font-weight: 800; font-size: 1.1rem; color: var(--text-main); margin-bottom: 0.5rem;">
                                    Cuentas Externas</h3>
                                <p style="font-size: 0.75rem; color: var(--text-muted); font-weight: 600;">Capital de
                                    origen externo al presupuesto. (Total Prestado: S/ <%= extTotal.toFixed(2) %>)</p>
                            </div>
                            <div style="padding-right: 1rem; border-right: 1px solid var(--border);"
                                class="loan-stat-item">
                                <span
                                    style="font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Cuentas
                                    Pendientes</span>
                                <h3 style="font-size: 1.75rem; font-weight: 800; color: var(--warning);">S/ <%=
                                        extPending.toFixed(2) %>
                                </h3>
                            </div>
                            <div style="padding-left: 0.5rem;" class="loan-stat-item">
                                <span
                                    style="font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Total
                                    Recuperado</span>
                                <h3 style="font-size: 1.75rem; font-weight: 800; color: var(--success);">S/ <%=
                                        extRecovered.toFixed(2) %>
                                </h3>
                            </div>
                            <div
                                style="grid-column: 1 / -1; height: 8px; background: #f1f5f9; border-radius: 99px; overflow: hidden;">
                                <div
                                    style="width: <%= (extRecovered/extTotal)*100 || 0 %>%; height: 100%; background: var(--success);">
                                </div>
                            </div>
                        </div>

                        <!-- Budget Loans block -->
                        <div class="premium-card"
                            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1.5rem; align-items: center; border-left: 5px solid var(--info);">
                            <div style="grid-column: 1 / -1;">
                                <h3
                                    style="font-weight: 800; font-size: 1.1rem; color: var(--text-main); margin-bottom: 0.5rem;">
                                    Cuentas de Presupuesto</h3>
                                <p style="font-size: 0.75rem; color: var(--text-muted); font-weight: 600;">Capital
                                    restado de los fondos presupuestados. (Total Prestado: S/ <%= budTotal.toFixed(2) %>
                                        )</p>
                            </div>
                            <div style="padding-right: 1rem; border-right: 1px solid var(--border);"
                                class="loan-stat-item">
                                <span
                                    style="font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Cuentas
                                    Pendientes</span>
                                <h3 style="font-size: 1.75rem; font-weight: 800; color: var(--warning);">S/ <%=
                                        budPending.toFixed(2) %>
                                </h3>
                            </div>
                            <div style="padding-left: 0.5rem;" class="loan-stat-item">
                                <span
                                    style="font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Total
                                    Recuperado</span>
                                <h3 style="font-size: 1.75rem; font-weight: 800; color: var(--success);">S/ <%=
                                        budRecovered.toFixed(2) %>
                                </h3>
                            </div>
                            <div
                                style="grid-column: 1 / -1; height: 8px; background: #f1f5f9; border-radius: 99px; overflow: hidden;">
                                <div
                                    style="width: <%= (budRecovered/budTotal)*100 || 0 %>%; height: 100%; background: var(--success);">
                                </div>
                            </div>
                        </div>
                </div>
                <div class="premium-card animate-slide-up" style="padding: 0; overflow: hidden; animation-delay: 0.2s;">
                    <div class="table-container">
                        <table class="data-table mobile-cards">
                            <thead>
                                <tr>
                                    <th style="padding-left: 1.5rem;">Beneficiario</th>
                                    <th>Monto</th>
                                    <th>Fecha</th>
                                    <th>Estado</th>
                                    <th>Detalles</th>
                                    <th style="text-align: center; padding-right: 1.5rem;">Gestión</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (loans && loans.length> 0) { %>
                                    <% loans.forEach(loan=> { %>
                                        <tr class="<%= loan.status === 'paid' ? 'row-completed' : '' %>">
                                            <td style="padding-left: 1.5rem;" data-label="Beneficiario">
                                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                                    <div
                                                        style="width: 36px; height: 36px; background: var(--bg-alt); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--primary);">
                                                        <%= loan.person_name.charAt(0).toUpperCase() %>
                                                    </div>
                                                    <span style="font-weight: 700; color: var(--text-main);">
                                                        <%= loan.person_name %>
                                                    </span>
                                                </div>
                                            </td>
                                            <td data-label="Monto">
                                                <div
                                                    style="font-weight: 800; color: var(--text-main); font-size: 1.1rem;">
                                                    S/ <%= parseFloat(loan.amount).toFixed(2) %>
                                                </div>
                                                <% if (parseFloat(loan.paid_amount || 0)> 0) { %>
                                                    <div
                                                        style="font-size: 0.75rem; color: var(--success); font-weight: 700; background: var(--success-light); padding: 0.2rem 0.5rem; border-radius: 1rem; display: inline-block; margin-top: 0.25rem;">
                                                        Abonado: S/ <%= parseFloat(loan.paid_amount || 0).toFixed(2) %>
                                                    </div>
                                                    <% } %>
                                            </td>
                                            <td data-label="Fecha"
                                                style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">
                                                <%= new Date(loan.date).toLocaleDateString('es-ES') %>
                                            </td>
                                            <td data-label="Estado">
                                                <span class="status-badge <%= loan.status %>">
                                                    <%= loan.status==='pending' ? 'Pendiente' : 'Finalizado' %>
                                                </span>
                                            </td>
                                            <td data-label="Detalles"
                                                style="font-size: 0.8125rem; color: var(--text-muted); max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                <%= loan.description || 'Sin notas' %>
                                            </td>
                                            <td data-label="Gestión" style="text-align: center; padding-right: 1.5rem;">
                                                <div style="display: flex; gap: 0.75rem; justify-content: center;">
                                                    <button type="button" class="btn-action"
                                                        style="background: #f1f5f9; color: var(--primary);"
                                                        onclick="openEditLoanModal('<%= loan.id %>', '<%= loan.person_name %>', '<%= loan.amount %>', '<%= loan.date %>', '<%= loan.description %>', <%= loan.from_budget %>)">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <% if (loan.status==='pending' ) { %>
                                                        <button type="button" class="btn-action success"
                                                            title="Abonar Pago"
                                                            onclick="openPayLoanModal('<%= loan.id %>', '<%= Buffer.from(loan.person_name).toString(`base64`) %>', <%= parseFloat(loan.amount) - parseFloat(loan.paid_amount || 0) %>)">
                                                            <i class="fas fa-hand-holding-dollar"></i>
                                                        </button>
                                                        <% } else { %>
                                                            <form action="/loans/undo/<%= loan.id %>" method="POST"
                                                                onsubmit="showLoading()">
                                                                <button type="submit" class="btn-action undo"
                                                                    title="Reabrir">
                                                                    <i class="fas fa-rotate-left"></i>
                                                                </button>
                                                            </form>
                                                            <% } %>
                                                                <form id="deleteLoanForm-<%= loan.id %>"
                                                                    action="/loans/delete/<%= loan.id %>" method="POST">
                                                                    <button type="button" class="btn-action delete"
                                                                        data-id="<%= loan.id %>"
                                                                        data-person="<%= loan.person_name %>"
                                                                        onclick="confirmDeleteLoan(this)">
                                                                        <i class="fas fa-trash-can"></i>
                                                                    </button>
                                                                </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="6" style="text-align: center; padding: 6rem 2rem;">
                                                        <div
                                                            style="font-size: 3.5rem; margin-bottom: 1.5rem; color: #e2e8f0;">
                                                            <i class="fas fa-handshake-angle"></i>
                                                        </div>
                                                        <h3 style="color: var(--text-main); font-weight: 800;">No hay
                                                            préstamos activos</h3>
                                                        <p style="color: var(--text-muted); margin-top: 0.5rem;">Tus
                                                            deudas y cobranzas aparecerán aquí.</p>
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
    </div>
    <div id="loanModal" class="modal">
        <div class="modal-content" style="max-width: 550px; border-radius: 1.5rem; border: none; padding: 2.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                <div>
                    <h2 style="font-weight: 800; color: var(--text-main); font-size: 1.5rem;">Nuevo Préstamo</h2>
                    <p style="font-size: 0.875rem; color: var(--text-muted); margin-top: 0.25rem;">Registra una nueva
                        cuenta por cobrar.</p>
                </div>
                <span class="close" onclick="toggleModal('loanModal')"
                    style="font-size: 1.75rem; color: var(--text-muted); cursor: pointer;">&times;</span>
            </div>

            <form action="/loans/add" method="POST">
                <div class="form-group">
                    <label
                        style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">A
                        favor de (Persona)</label>
                    <input type="text" name="person_name" required placeholder="Prestado a"
                        style="padding: 1rem; border-radius: 0.75rem; font-weight: 600;">
                </div>

                <div class="responsive-modal-grid">
                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Monto
                            (S/)</label>
                        <input type="number" step="0.01" name="amount" required placeholder="0.00"
                            style="padding: 1rem; border-radius: 0.75rem; font-weight: 800; font-size: 1.1rem;">
                    </div>
                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Fuente</label>
                        <select name="from_budget"
                            style="padding: 1rem 0.5rem; border-radius: 0.75rem; font-weight: 600; background: var(--bg-alt); text-overflow: ellipsis;">
                            <option value="false">Externo</option>
                            <option value="true">Presupuesto</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Fecha</label>
                        <input type="date" name="date"
                            value="<%= typeof todayDate !== 'undefined' ? todayDate : new Date().toISOString().split('T')[0] %>"
                            style="padding: 1rem; border-radius: 0.75rem;">
                    </div>
                </div>

                <style>
                    .responsive-modal-grid {
                        display: grid;
                        grid-template-columns: 1fr 1.1fr 1fr;
                        gap: 0.75rem;
                    }

                    @media (max-width: 600px) {
                        .responsive-modal-grid {
                            grid-template-columns: 1fr !important;
                        }
                    }
                </style>

                <div class="form-group">
                    <label
                        style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Descripción
                        / Notas</label>
                    <textarea name="description" rows="3" placeholder="Opcional..."
                        style="padding: 1rem; border-radius: 0.75rem; font-family: inherit; font-size: 0.9rem;"></textarea>
                </div>

                <div style="margin-top: 1rem;">
                    <button type="submit" class="btn btn-primary"
                        style="width: 100%; justify-content: center; padding: 1.25rem; border-radius: 1rem; font-size: 1rem; font-weight: 700;">
                        <i class="fas fa-save" style="margin-right: 0.5rem;"></i> Registrar Préstamo
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Loan Modal -->
    <div id="editLoanModal" class="modal">
        <div class="modal-content" style="max-width: 550px; border-radius: 1.5rem; border: none; padding: 2.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                <div>
                    <h2 style="font-weight: 800; color: var(--text-main); font-size: 1.5rem;">Editar Préstamo</h2>
                </div>
                <span class="close" onclick="closeEditLoanModal()"
                    style="font-size: 1.75rem; color: var(--text-muted); cursor: pointer;">&times;</span>
            </div>

            <form id="editLoanForm" method="POST">
                <div class="form-group">
                    <label
                        style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">A
                        favor de (Persona)</label>
                    <input type="text" name="person_name" id="editLoanPerson" required placeholder="Prestado a"
                        style="padding: 1rem; border-radius: 0.75rem; font-weight: 600;">
                </div>

                <div class="responsive-modal-grid">
                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Monto
                            (S/)</label>
                        <input type="number" step="0.01" name="amount" id="editLoanAmount" required placeholder="0.00"
                            style="padding: 1rem; border-radius: 0.75rem; font-weight: 800; font-size: 1.1rem;">
                    </div>
                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Fuente</label>
                        <select name="from_budget" id="editLoanSource"
                            style="padding: 1rem 0.5rem; border-radius: 0.75rem; font-weight: 600; background: var(--bg-alt); text-overflow: ellipsis;">
                            <option value="false">Externo</option>
                            <option value="true">Presupuesto</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Fecha</label>
                        <input type="date" name="date" id="editLoanDate" required
                            style="padding: 1rem; border-radius: 0.75rem;">
                    </div>
                </div>

                <div class="form-group">
                    <label
                        style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Descripción
                        / Notas</label>
                    <textarea name="description" id="editLoanDesc" rows="3" placeholder="Opcional..."
                        style="padding: 1rem; border-radius: 0.75rem; font-family: inherit; font-size: 0.9rem;"></textarea>
                </div>

                <div style="margin-top: 1rem;">
                    <button type="submit" class="btn btn-primary"
                        style="width: 100%; justify-content: center; padding: 1.25rem; border-radius: 1rem; font-size: 1rem; font-weight: 700;">
                        <i class="fas fa-save" style="margin-right: 0.5rem;"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Pay Loan Modal -->
    <div id="payLoanModal" class="modal">
        <div class="modal-content" style="max-width: 450px; border-radius: 1.5rem; border: none; padding: 2.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                <div>
                    <h2 style="font-weight: 800; color: var(--text-main); font-size: 1.5rem;">Abonar Préstamo</h2>
                    <p id="payLoanPerson" style="font-size: 0.875rem; color: var(--text-muted); margin-top: 0.25rem;">
                    </p>
                </div>
                <span class="close" onclick="closePayLoanModal()"
                    style="font-size: 1.75rem; color: var(--text-muted); cursor: pointer;">&times;</span>
            </div>

            <form id="payLoanForm" method="POST">
                <div class="form-group">
                    <label
                        style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Monto
                        a Abonar (S/)</label>
                    <input type="number" step="0.01" name="amount" id="payLoanAmount" required placeholder="0.00"
                        style="padding: 1rem; border-radius: 0.75rem; font-weight: 800; font-size: 1.5rem; color: var(--primary);">
                    <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; font-weight: 600;">
                        Deuda restante: S/ <span id="payLoanRemaining">0.00</span>
                    </div>
                </div>

                <div style="margin-top: 1.5rem;">
                    <button type="submit" class="btn btn-primary success"
                        style="width: 100%; justify-content: center; padding: 1.25rem; border-radius: 1rem; font-size: 1rem; font-weight: 700; background: var(--success) !important;">
                        <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i> Confirmar Abono
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function confirmDeleteLoan(btn) {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-person');
            customConfirm({
                title: 'Eliminar Préstamo',
                message: `¿Estás seguro de eliminar el préstamo de ${name}? Esta acción podría afectar tu presupuesto si es un préstamo activo.`,
                onConfirm: () => {
                    showLoading();
                    document.getElementById(`deleteLoanForm-${id}`).submit();
                }
            });
        }

        function showLoading() {
            document.getElementById('loadingOverlay').style.display = 'flex';
        }

        // Show toast if redirected with success
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('updated')) {
            const toast = document.getElementById('toast');
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function toggleModal(id) {
            const modal = document.getElementById(id);
            if (modal.style.display === 'flex') {
                modal.style.display = 'none';
                document.body.classList.remove('modal-open');
            } else {
                modal.style.display = 'flex';
                document.body.classList.add('modal-open');
            }
        }

        function openEditLoanModal(id, person, amount, dateStr, desc, fromBudget) {
            document.getElementById('editLoanForm').action = '/loans/edit/' + id;
            document.getElementById('editLoanPerson').value = person;
            document.getElementById('editLoanAmount').value = amount;

            const parseDate = (d) => {
                return new Date(d).toISOString().split('T')[0];
            };
            document.getElementById('editLoanDate').value = parseDate(dateStr);
            document.getElementById('editLoanDesc').value = desc;
            document.getElementById('editLoanSource').value = fromBudget ? 'true' : 'false';

            document.getElementById('editLoanModal').style.display = 'flex';
            document.body.classList.add('modal-open');
        }

        function closeEditLoanModal() {
            document.getElementById('editLoanModal').style.display = 'none';
            document.body.classList.remove('modal-open');
        }

        function openPayLoanModal(id, personBase64, remaining) {
            const decodedPerson = atob(personBase64);
            document.getElementById('payLoanForm').action = '/loans/pay/' + id;
            document.getElementById('payLoanPerson').textContent = 'Cobro a ' + decodedPerson;
            document.getElementById('payLoanRemaining').textContent = Number(remaining).toFixed(2);
            document.getElementById('payLoanAmount').value = Number(remaining).toFixed(2);
            document.getElementById('payLoanAmount').max = Number(remaining).toFixed(2);

            document.getElementById('payLoanModal').style.display = 'flex';
            document.body.classList.add('modal-open');
        }

        function closePayLoanModal() {
            document.getElementById('payLoanModal').style.display = 'none';
            document.body.classList.remove('modal-open');
        }

        window.onclick = function (event) {
            if (event.target.className.includes('modal') || event.target.id === 'payLoanModal' || event.target.id === 'editLoanModal') {
                event.target.style.display = "none";
                document.body.classList.remove('modal-open');
            }
        }
    </script>
</body>

