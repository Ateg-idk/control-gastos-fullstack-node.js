<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movimientos - GastosMoni</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body>
    <div class="container" style="display: flex; min-height: 100vh;">
        <%- include('../partials/sidebar', { activePage: 'expenses' }) %>

            <main class="main-content">
                <header class="top-nav animate-slide-up">
                    <div class="welcome-text">
                        <h1>Historial de Movimientos</h1>
                        <p>Visualiza y gestiona todos tus registros de gastos.</p>
                    </div>
                    <div class="header-actions">
                        <button onclick="openModal()" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Nuevo Gasto
                        </button>
                    </div>
                </header>

                <!-- Daily and Weekly Stats -->
                <div class="stats-grid animate-slide-up" style="margin-bottom: 2rem; gap: 1.5rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
                    <div class="premium-card" style="border-top: 5px solid var(--danger); cursor: pointer; transition: transform 0.2s;" onclick="window.location.href='/expenses?filter=today'" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                        <div class="stat-header" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <div class="stat-icon" style="background: #fee2e2; color: var(--danger); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                                <i class="fas fa-calendar-day"></i>
                            </div>
                            <span class="stat-label" style="font-weight: 700; color: var(--text-muted); text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;"><%= statsLabels ? statsLabels.day : 'Gastos de Hoy' %></span>
                        </div>
                        <h2 class="stat-value" style="font-size: 2rem; font-weight: 900; color: var(--text-main);">S/ <%= typeof dailyTotal !== 'undefined' ? dailyTotal.toFixed(2) : '0.00' %></h2>
                        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; font-weight: 600;">
                            Total registrado en el transcurso de hoy
                        </p>
                    </div>

                    <div class="premium-card" style="border-top: 5px solid var(--warning); cursor: pointer; transition: transform 0.2s;" onclick="window.location.href='/expenses?filter=week'" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                        <div class="stat-header" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <div class="stat-icon" style="background: #fef3c7; color: var(--warning); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                                <i class="fas fa-calendar-week"></i>
                            </div>
                            <span class="stat-label" style="font-weight: 700; color: var(--text-muted); text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;"><%= statsLabels ? statsLabels.week : 'Gastos de la Semana' %></span>
                        </div>
                        <h2 class="stat-value" style="font-size: 2rem; font-weight: 900; color: var(--text-main);">S/ <%= typeof weeklyTotal !== 'undefined' ? weeklyTotal.toFixed(2) : '0.00' %></h2>
                        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; font-weight: 600;">
                            Acumulado de Lunes a Domingo
                        </p>
                    </div>
                </div>

                <!-- Professional Filters -->
                <div class="premium-card animate-slide-up"
                    style="margin-bottom: 2rem; padding: 1.5rem; animation-delay: 0.1s;">
                    <form action="/expenses" method="GET"
                        style="display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap;">
                        <div class="form-group" style="flex: 2; margin-bottom: 0;">
                            <label
                                style="font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); margin-bottom: 0.5rem; display: block;">Buscar
                                Movimiento</label>
                            <div style="position: relative;">
                                <i class="fas fa-search"
                                    style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                                <input type="text" name="search" placeholder="Buscar por concepto o notas..."
                                    value="<%= filters.search || '' %>"
                                    style="padding-left: 2.75rem; border-radius: 0.75rem;">
                            </div>
                        </div>
                        <div class="form-group" style="flex: 1; margin-bottom: 0;">
                            <label
                                style="font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); margin-bottom: 0.5rem; display: block;">Día Específico</label>
                            <input type="date" name="day" value="<%= filters.day || '' %>"
                                style="border-radius: 0.75rem;">
                        </div>
                        <div class="form-group" style="flex: 1; margin-bottom: 0;">
                            <label
                                style="font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); margin-bottom: 0.5rem; display: block;">Semana Específica</label>
                            <input type="week" name="week" value="<%= filters.week || '' %>"
                                style="border-radius: 0.75rem;">
                        </div>
                        <div style="display: flex; gap: 0.75rem;">
                            <button type="submit" class="btn btn-primary"
                                style="padding: 0.75rem 1.5rem; border-radius: 0.75rem;">
                                <i class="fas fa-search"></i> Buscar
                            </button>
                            <a href="/expenses?filter=week" class="btn"
                                style="background: <%= filters.filter==='week' ? 'var(--primary)' : 'var(--bg-alt)' %>; color: <%= filters.filter==='week' ? 'white' : 'var(--text-main)' %>; font-weight: 700; border-radius: 0.75rem; padding: 0.75rem 1.5rem;">
                                <i class="fas fa-calendar-week"></i> Esta Semana
                            </a>
                            <% if (filters.search || filters.day || filters.week || filters.filter === 'today') { %>
                                <a href="/expenses?filter=all" class="btn" title="Mostrar Todos"
                                    style="background: var(--bg-alt); color: var(--text-main); font-weight: 700; border-radius: 0.75rem; padding: 0.75rem 1rem;">
                                    Todos
                                </a>
                                <% } %>
                        </div>
                    </form>
                </div>

                <!-- Main Data Table -->
                <div class="premium-card animate-slide-up" style="padding: 0; overflow: hidden; animation-delay: 0.2s;">
                    <div class="table-container">
                        <table class="data-table mobile-cards">
                            <thead>
                                <tr>
                                    <th style="padding-left: 1.5rem;">Fecha</th>
                                    <th>Concepto & Detalles</th>
                                    <th>Categoría</th>
                                    <th style="text-align: right;">Monto</th>
                                    <th style="text-align: center; padding-right: 1.5rem;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (expenses && expenses.length> 0) { %>
                                    <% let lastExpDate = null; %>
                                    <% expenses.forEach(exp=> { %>
                                        <% 
                                            const currentExpDate = new Date(exp.date).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' }); 
                                            if (lastExpDate !== currentExpDate) { 
                                        %>
                                            <tr style="background: var(--bg-alt);">
                                                <td colspan="5" style="padding: 0.75rem 1.5rem; font-weight: 800; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">
                                                    <i class="fas fa-calendar-alt" style="margin-right: 0.5rem;"></i> <%= currentExpDate %>
                                                </td>
                                            </tr>
                                        <%      lastExpDate = currentExpDate; 
                                            } 
                                        %>
                                        <tr>
                                            <td style="padding-left: 1.5rem;" data-label="Fecha">
                                                <div
                                                    style="font-weight: 800; color: var(--text-main); font-size: 0.95rem;">
                                                    <%= new Date(exp.date).toLocaleDateString('es-ES', { day: '2-digit'
                                                        }) %>
                                                </div>
                                                <div
                                                    style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700;">
                                                    <%= new Date(exp.date).toLocaleDateString('es-ES', { month: 'short'
                                                        }) %>
                                                </div>
                                            </td>
                                            <td data-label="Concepto">
                                                <div style="font-weight: 700; color: var(--text-main);">
                                                    <%= exp.name %>
                                                </div>
                                                <div
                                                    style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.4;">
                                                    <%= exp.description || 'Sin descripción adicional' %>
                                                </div>
                                            </td>
                                            <td data-label="Categoría">
                                                <span
                                                    style="font-size: 0.65rem; font-weight: 800; background: var(--bg-alt); color: var(--primary); padding: 0.4rem 0.8rem; border-radius: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid var(--border);">
                                                    <%= exp.category || 'Otros' %>
                                                </span>
                                            </td>
                                            <td style="text-align: right;" data-label="Monto">
                                                <span
                                                    style="color: <%= exp.amount < 0 ? 'var(--success)' : 'var(--danger)' %>; font-weight: 900; font-size: 1.05rem;">
                                                    <%= exp.amount < 0 ? '+ S/' : '- S/' %> <%= Math.abs(parseFloat(exp.amount)).toFixed(2) %>
                                                </span>
                                            </td>
                                            <td style="text-align: center; padding-right: 1.5rem;"
                                                data-label="Acciones">
                                                <div style="display: flex; gap: 0.5rem; justify-content: center;">
                                                    <button type="button"
                                                        style="background: none; border: none; cursor: pointer; color: #94a3b8; transition: all 0.2s;"
                                                        onmouseover="this.style.color='var(--primary)'"
                                                        onmouseout="this.style.color='#94a3b8'"
                                                        onclick="openEditExpenseModal('<%= exp.id %>', '<%= exp.name %>', '<%= exp.amount %>', '<%= exp.date %>', '<%= exp.description %>', '<%= exp.category %>')">
                                                        <i class="fas fa-edit" style="font-size: 1.1rem;"></i>
                                                    </button>
                                                    <form id="deleteExpForm-<%= exp.id %>" action="/expenses/delete/<%= exp.id %>" method="POST">
                                                        <button type="button"
                                                            style="background: none; border: none; cursor: pointer; color: #94a3b8; transition: all 0.2s;"
                                                            onmouseover="this.style.color='var(--danger)'"
                                                            onmouseout="this.style.color='#94a3b8'"
                                                            data-id="<%= exp.id %>" data-name="<%= exp.name %>"
                                                            onclick="confirmDeleteExpense(this)">
                                                            <i class="fas fa-trash-alt" style="font-size: 1.1rem;"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="5" style="text-align: center; padding: 6rem 2rem;">
                                                        <div
                                                            style="font-size: 3.5rem; margin-bottom: 1.5rem; color: #e2e8f0;">
                                                            <i class="fas fa-folder-open"></i>
                                                        </div>
                                                        <h3
                                                            style="color: var(--text-main); font-weight: 800; margin-bottom: 0.5rem;">
                                                            No hay registros</h3>
                                                        <p style="color: var(--text-muted);">No encontramos movimientos
                                                            que coincidan con tu búsqueda.</p>
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    
                    <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; border-top: 1px solid var(--border);">
                        <% if (pagination.currentPage > 1) { %>
                            <a href="/expenses?page=<%= pagination.currentPage - 1 %><%= filters.search ? '&search='+filters.search : '' %><%= filters.day ? '&day='+filters.day : '' %><%= filters.week ? '&week='+filters.week : '' %><%= filters.filter ? '&filter='+filters.filter : '' %>" class="btn" style="background: var(--bg-alt); padding: 0.75rem 1.25rem; border-radius: 0.75rem; color: var(--text-main); font-weight: 700;">
                                <i class="fas fa-chevron-left"></i> Anterior
                            </a>
                        <% } else { %>
                            <div></div>
                        <% } %>
                        
                        <span style="font-size: 0.85rem; font-weight: 800; color: var(--text-muted); padding: 0 1rem; background: var(--bg-alt); padding: 0.5rem 1rem; border-radius: 2rem;">
                            Página <%= pagination.currentPage %> de <%= pagination.totalPages %>
                        </span>

                        <% if (pagination.currentPage < pagination.totalPages) { %>
                            <a href="/expenses?page=<%= pagination.currentPage + 1 %><%= filters.search ? '&search='+filters.search : '' %><%= filters.day ? '&day='+filters.day : '' %><%= filters.week ? '&week='+filters.week : '' %><%= filters.filter ? '&filter='+filters.filter : '' %>" class="btn" style="background: var(--bg-alt); padding: 0.75rem 1.25rem; border-radius: 0.75rem; color: var(--text-main); font-weight: 700;">
                                Siguiente <i class="fas fa-chevron-right"></i>
                            </a>
                        <% } else { %>
                            <div></div>
                        <% } %>
                    </div>
                    <% } %>
                </div>
            </main>
    </div>

    <!-- Expense Registration Modal -->
    <div class="modal" id="expenseModal">
        <div class="modal-content animate-slide-up" style="max-width: 600px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <h2 style="font-weight: 800; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="fas fa-plus-circle" style="color: var(--primary);"></i>
                    Nuevo Gasto
                </h2>
                <button type="button" class="btn" style="background: none; padding: 0.5rem; color: var(--text-muted);"
                    onclick="closeModal()">
                    <i class="fas fa-times" style="font-size: 1.25rem;"></i>
                </button>
            </div>

            <form action="/expenses/add" method="POST">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <div class="form-group" style="grid-column: span 2;">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Concepto</label>
                        <input type="text" name="name" required placeholder="Ej: Supermercado..."
                            style="padding: 1rem; border-radius: 0.75rem;">
                    </div>

                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Monto
                            (S/.)</label>
                        <input type="number" step="0.01" name="amount" required placeholder="0.00"
                            style="padding: 1rem; border-radius: 0.75rem; font-weight: 800;">
                    </div>

                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Fecha</label>
                        <input type="date" name="date" required value="<%= typeof todayDate !== 'undefined' ? todayDate : new Date().toISOString().split('T')[0] %>"
                            style="padding: 1rem; border-radius: 0.75rem;">
                    </div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Detalles
                            opcionales</label>
                        <textarea name="description" placeholder="Notas adicionales..." rows="2"
                            style="padding: 1rem; border-radius: 0.75rem; font-family: inherit; font-size: 0.9rem;"></textarea>
                    </div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em; margin-bottom: 0.75rem; display: block;">Categoría</label>
                        <div class="category-grid" style="grid-template-columns: repeat(3, 1fr);">
                            <div class="category-option selected" onclick="modalSelectCategory('Otros', this)">
                                <i class="fas fa-grid-horizontal"></i>
                                <span style="font-size: 0.6rem;">Otros</span>
                            </div>
                            <div class="category-option" onclick="modalSelectCategory('Comida', this)">
                                <i class="fas fa-utensils"></i>
                                <span style="font-size: 0.6rem;">Comida</span>
                            </div>
                            <div class="category-option" onclick="modalSelectCategory('Transporte', this)">
                                <i class="fas fa-car-side"></i>
                                <span style="font-size: 0.6rem;">Transp.</span>
                            </div>
                            <div class="category-option" onclick="modalSelectCategory('Servicios', this)">
                                <i class="fas fa-plug"></i>
                                <span style="font-size: 0.6rem;">Servic.</span>
                            </div>
                            <div class="category-option" onclick="modalSelectCategory('Ocio', this)">
                                <i class="fas fa-clapperboard"></i>
                                <span style="font-size: 0.6rem;">Ocio</span>
                            </div>
                            <div class="category-option" onclick="modalSelectCategory('Salud', this)">
                                <i class="fas fa-heart-pulse"></i>
                                <span style="font-size: 0.6rem;">Salud</span>
                            </div>
                        </div>
                        <input type="hidden" name="category" id="modalCategoryInput" value="Otros">
                    </div>
                </div>

                <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary"
                        style="flex: 1; justify-content: center; padding: 1.125rem; border-radius: 0.75rem; font-weight: 800;">
                        Registrar Movimiento
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Expense Modal -->
    <div class="modal" id="editExpenseModal">
        <div class="modal-content animate-slide-up" style="max-width: 600px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <h2 style="font-weight: 800; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="fas fa-edit" style="color: var(--primary);"></i>
                    Editar Gasto
                </h2>
                <button type="button" class="btn" style="background: none; padding: 0.5rem; color: var(--text-muted);"
                    onclick="closeEditExpenseModal()">
                    <i class="fas fa-times" style="font-size: 1.25rem;"></i>
                </button>
            </div>

            <form id="editExpenseForm" method="POST">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <div class="form-group" style="grid-column: span 2;">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Concepto</label>
                        <input type="text" name="name" id="editExpenseName" required placeholder="Ej: Supermercado..."
                            style="padding: 1rem; border-radius: 0.75rem;">
                    </div>

                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Monto
                            (S/.)</label>
                        <input type="number" step="0.01" name="amount" id="editExpenseAmount" required placeholder="0.00"
                            style="padding: 1rem; border-radius: 0.75rem; font-weight: 800;">
                    </div>

                    <div class="form-group">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Fecha</label>
                        <input type="date" name="date" id="editExpenseDate" required
                            style="padding: 1rem; border-radius: 0.75rem;">
                    </div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em;">Detalles
                            opcionales</label>
                        <textarea name="description" id="editExpenseDescription" placeholder="Notas adicionales..." rows="2"
                            style="padding: 1rem; border-radius: 0.75rem; font-family: inherit; font-size: 0.9rem;"></textarea>
                    </div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label
                            style="text-transform: uppercase; font-size: 0.65rem; font-weight: 800; color: var(--text-muted); letter-spacing: 0.1em; margin-bottom: 0.75rem; display: block;">Categoría</label>
                        <div class="category-grid edit-category-grid" style="grid-template-columns: repeat(3, 1fr);">
                            <div class="category-option" data-cat="Otros" onclick="modalEditSelectCategory('Otros', this)">
                                <i class="fas fa-grid-horizontal"></i>
                                <span style="font-size: 0.6rem;">Otros</span>
                            </div>
                            <div class="category-option" data-cat="Comida" onclick="modalEditSelectCategory('Comida', this)">
                                <i class="fas fa-utensils"></i>
                                <span style="font-size: 0.6rem;">Comida</span>
                            </div>
                            <div class="category-option" data-cat="Transporte" onclick="modalEditSelectCategory('Transporte', this)">
                                <i class="fas fa-car-side"></i>
                                <span style="font-size: 0.6rem;">Transp.</span>
                            </div>
                            <div class="category-option" data-cat="Servicios" onclick="modalEditSelectCategory('Servicios', this)">
                                <i class="fas fa-plug"></i>
                                <span style="font-size: 0.6rem;">Servic.</span>
                            </div>
                            <div class="category-option" data-cat="Ocio" onclick="modalEditSelectCategory('Ocio', this)">
                                <i class="fas fa-clapperboard"></i>
                                <span style="font-size: 0.6rem;">Ocio</span>
                            </div>
                            <div class="category-option" data-cat="Salud" onclick="modalEditSelectCategory('Salud', this)">
                                <i class="fas fa-heart-pulse"></i>
                                <span style="font-size: 0.6rem;">Salud</span>
                            </div>
                        </div>
                        <input type="hidden" name="category" id="editModalCategoryInput" value="Otros">
                    </div>
                </div>

                <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary"
                        style="flex: 1; justify-content: center; padding: 1.125rem; border-radius: 0.75rem; font-weight: 800;">
                        Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Floating Action Button for Mobile / Quick Access -->
    <button type="button" class="fab" title="Registrar Movimiento" onclick="openModal()">
        <i class="fas fa-plus"></i>
    </button>

    <script>
        function confirmDeleteExpense(btn) {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            customConfirm({
                title: 'Eliminar Movimiento',
                message: `¿Estás seguro de eliminar "${name}"? El balance se ajustará automáticamente.`,
                onConfirm: () => {
                    document.getElementById(`deleteExpForm-${id}`).submit();
                }
            });
        }

        const modal = document.getElementById('expenseModal');

        function openModal() {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            document.body.classList.add('modal-open');
        }

        function closeModal() {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
            document.body.classList.remove('modal-open');
        }

        function modalSelectCategory(cat, el) {
            document.querySelectorAll('.modal .category-option').forEach(opt => opt.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('modalCategoryInput').value = cat;
        }

        function modalEditSelectCategory(cat, el) {
            document.querySelectorAll('#editExpenseModal .category-option').forEach(opt => opt.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('editModalCategoryInput').value = cat;
        }

        const editExpenseModal = document.getElementById('editExpenseModal');

        function openEditExpenseModal(id, name, amount, dateStr, desc, category) {
            document.getElementById('editExpenseForm').action = '/expenses/edit/' + id;
            document.getElementById('editExpenseName').value = name;
            
            document.getElementById('editExpenseAmount').value = amount;
            
            const parseDate = (d) => {
                return new Date(d).toISOString().split('T')[0];
            };
            document.getElementById('editExpenseDate').value = parseDate(dateStr);
            document.getElementById('editExpenseDescription').value = desc;
            
            document.querySelectorAll('#editExpenseModal .category-option').forEach(opt => opt.classList.remove('selected'));
            const catOption = document.querySelector(`#editExpenseModal .category-option[data-cat="${category}"]`) || document.querySelector(`#editExpenseModal .category-option[data-cat="Otros"]`);
            if (catOption) catOption.classList.add('selected');
            
            document.getElementById('editModalCategoryInput').value = category || 'Otros';

            editExpenseModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            document.body.classList.add('modal-open');
        }

        function closeEditExpenseModal() {
            editExpenseModal.style.display = 'none';
            document.body.style.overflow = 'auto';
            document.body.classList.remove('modal-open');
        }

        // Close on clic outside
        window.onclick = function (event) {
            if (event.target == modal) {
                closeModal();
            }
            if (event.target == editExpenseModal) {
                closeEditExpenseModal();
            }
        }
    </script>
</body>

</html>