<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestionar Periodos - GastosMonini</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body>
    <div class="container" style="display: flex; min-height: 100vh;">
        <%- include('../partials/sidebar', { activePage: 'budget' }) %>

            <main class="main-content">
                <header class="top-nav animate-slide-up">
                    <div class="welcome-text">
                        <h1>Gestión de Presupuestos</h1>
                        <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.4; max-width: 100%;">
                            <%= 'Controla tus objetivos financieros mediante periodos personalizados.' %>
                        </p>
                    </div>
                </header>

                <div class="stats-grid animate-slide-up">
                    <div class="premium-card" style="border-top: 5px solid var(--primary);">
                        <h3
                            style="font-weight: 800; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                            <i class="fas fa-plus-circle" style="color: var(--primary);"></i>
                            Nuevo Periodo
                        </h3>

                        <form action="/budget/add" method="POST">
                            <div class="form-group">
                                <label
                                    style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Nombre
                                    del Periodo</label>
                                <input type="text" name="name" required placeholder="Ej: Quincena Marzo, Vacaciones..."
                                    style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%;"
                                    onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'">
                            </div>

                            <div class="form-group" style="margin-top: 1.5rem;">
                                <label
                                    style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Monto
                                    Presupuestado (S/.)</label>
                                <input type="number" step="0.01" name="amount" required placeholder="0.00"
                                    style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%; font-weight: 700; font-size: 1.25rem;"
                                    onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'">
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem;">
                                <div class="form-group">
                                    <label
                                        style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Fecha
                                        Inicio</label>
                                    <input type="date" name="start_date" required
                                        style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%;"
                                        onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'">
                                </div>
                                <div class="form-group">
                                    <label
                                        style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Fecha
                                        Fin</label>
                                    <input type="date" name="end_date" required
                                        style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%;"
                                        onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'">
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary"
                                style="width: 100%; padding: 1.25rem; font-weight: 800; margin-top: 2rem; justify-content: center; border-radius: 1rem;">
                                <i class="fas fa-play" style="margin-right: 0.75rem;"></i> Iniciar Nuevo Periodo
                            </button>
                        </form>
                    </div>

                    <!-- Current Active Period -->
                    <div class="premium-card" style="border-top: 5px solid var(--success); background: var(--bg-alt);">
                        <h3
                            style="font-weight: 800; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                            <i class="fas fa-bolt" style="color: var(--success);"></i>
                            Periodo Activo
                        </h3>

                        <% if (activePeriod) { %>
                            <div style="text-align: center; padding: 1rem 0;">
                                <h2
                                    style="font-weight: 900; font-size: 2.5rem; color: var(--text-main); margin-bottom: 0.5rem;">
                                    <%= activePeriod.name %>
                                </h2>
                                <div
                                    style="display: flex; align-items: center; justify-content: center; gap: 1rem; color: var(--text-muted); font-size: 0.875rem; font-weight: 600; margin-bottom: 2rem;">
                                    <span><i class="fas fa-calendar-day"></i>
                                        <%= new Date(activePeriod.start_date).toLocaleDateString() %>
                                    </span>
                                    <i class="fas fa-arrow-right" style="font-size: 0.7rem;"></i>
                                    <span><i class="fas fa-calendar-check"></i>
                                        <%= new Date(activePeriod.end_date).toLocaleDateString() %>
                                    </span>
                                </div>
                                <div
                                    style="background: white; padding: 2rem; border-radius: 1.5rem; border: 1px solid var(--border); box-shadow: var(--shadow-sm); margin-bottom: 2.5rem;">
                                    <span
                                        style="font-size: 0.7rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;">Presupuesto
                                        Total</span>
                                    <h3
                                        style="font-size: 2rem; font-weight: 900; color: var(--primary); margin-top: 0.5rem;">
                                        S/ <%= parseFloat(activePeriod.amount).toFixed(2) %>
                                    </h3>
                                </div>

                                <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                                    <button type="button" class="btn"
                                        style="flex: 1; min-width: 200px; background: white; color: var(--primary); font-weight: 800; padding: 1.25rem; border-radius: 1rem; justify-content: center; border: 1px solid var(--primary);"
                                        onclick="openEditBudgetModal('<%= activePeriod.id %>', '<%= activePeriod.name %>', '<%= activePeriod.amount %>', '<%= activePeriod.start_date %>', '<%= activePeriod.end_date %>')">
                                        <i class="fas fa-edit" style="margin-right: 0.75rem;"></i> Editar
                                    </button>
                                    <form action="/budget/close/<%= activePeriod.id %>" method="POST"
                                        style="flex: 1; min-width: 200px;"
                                        onsubmit="return confirm('¿Estás seguro de cerrar este periodo? Se guardará en el historial.')">
                                        <button type="submit" class="btn"
                                            style="width: 100%; background: #fee2e2; color: var(--danger); font-weight: 800; padding: 1.25rem; border-radius: 1rem; justify-content: center;">
                                            <i class="fas fa-lock" style="margin-right: 0.75rem;"></i> Finalizar Periodo
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <% } else { %>
                                <div style="text-align: center; padding: 4rem 2rem;">
                                    <i class="fas fa-ghost"
                                        style="font-size: 3.5rem; color: #cbd5e1; margin-bottom: 1.5rem;"></i>
                                    <h4 style="color: var(--text-main); font-weight: 800;">No hay periodo activo</h4>
                                    <p style="color: var(--text-muted); font-size: 0.875rem; margin-top: 0.5rem;">Crea
                                        uno nuevo para comenzar a trackear tus gastos.</p>
                                </div>
                                <% } %>
                    </div>
                </div>

                <!-- History Section -->
                <div class="premium-card animate-slide-up" style="margin-top: 2rem;">
                    <h3
                        style="font-weight: 800; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                        <i class="fas fa-clock-rotate-left" style="color: var(--primary);"></i>
                        Historial de Periodos
                    </h3>

                    <div class="table-container">
                        <table class="data-table mobile-cards">
                            <thead>
                                <tr>
                                    <th style="padding-left: 1.5rem;">Nombre</th>
                                    <th>Rango de Fechas</th>
                                    <th style="text-align: right;">Presupuesto</th>
                                    <th style="text-align: center;">Estado</th>
                                    <th style="text-align: center; padding-right: 1.5rem;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (history && history.length> 0) { %>
                                    <% history.forEach(p=> { %>
                                        <tr>
                                            <td style="padding-left: 1.5rem; font-weight: 800; color: var(--text-main);"
                                                data-label="Nombre">
                                                <%= p.name %>
                                            </td>
                                            <td data-label="Rango">
                                                <span
                                                    style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">
                                                    <%= new Date(p.start_date).toLocaleDateString() %> - <%= new
                                                            Date(p.end_date).toLocaleDateString() %>
                                                </span>
                                            </td>
                                            <td style="text-align: right; font-weight: 800;" data-label="Presupuesto">S/
                                                <%= parseFloat(p.amount).toFixed(2) %>
                                            </td>
                                            <td style="text-align: center;" data-label="Estado">
                                                <span class="status-badge paid">Cerrado</span>
                                            </td>
                                            <td style="text-align: center; padding-right: 1.5rem;"
                                                data-label="Acciones">
                                                <button type="button"
                                                    style="background: none; border: none; cursor: pointer; color: #94a3b8; transition: all 0.2s;"
                                                    onmouseover="this.style.color='var(--primary)'"
                                                    onmouseout="this.style.color='#94a3b8'"
                                                    onclick="openEditBudgetModal('<%= p.id %>', '<%= p.name %>', '<%= p.amount %>', '<%= p.start_date %>', '<%= p.end_date %>')">
                                                    <i class="fas fa-edit" style="font-size: 1.1rem;"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="5" style="text-align: center; padding: 3rem;">No hay
                                                        periodos anteriores registrados.</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
    </div>

    <!-- Edit Budget Modal -->
    <div class="modal" id="editBudgetModal">
        <div class="modal-content animate-slide-up" style="max-width: 500px; padding: 2.5rem; border-radius: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                <div>
                    <h2 style="font-weight: 800; color: var(--text-main); font-size: 1.5rem;">Editar Periodo</h2>
                </div>
                <button type="button" class="btn" style="background: none; padding: 0.5rem; color: var(--text-muted);"
                    onclick="closeEditBudgetModal()">
                    <i class="fas fa-times" style="font-size: 1.25rem;"></i>
                </button>
            </div>

            <form id="editBudgetForm" method="POST">
                <div class="form-group">
                    <label
                        style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Nombre
                        del Periodo</label>
                    <input type="text" name="name" id="editBudgetName" required
                        style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%;">
                </div>

                <div class="form-group" style="margin-top: 1.5rem;">
                    <label
                        style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Monto
                        Presupuestado (S/.)</label>
                    <input type="number" step="0.01" name="amount" id="editBudgetAmount" required
                        style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%; font-weight: 700; font-size: 1.25rem;">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem;">
                    <div class="form-group">
                        <label
                            style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Fecha
                            Inicio</label>
                        <input type="date" name="start_date" id="editBudgetStartDate" required
                            style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%;">
                    </div>
                    <div class="form-group">
                        <label
                            style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Fecha
                            Fin</label>
                        <input type="date" name="end_date" id="editBudgetEndDate" required
                            style="background: var(--bg-alt); border: 2px solid transparent; border-radius: 1rem; padding: 1rem; width: 100%;">
                    </div>
                </div>

                <button type="submit" class="btn btn-primary"
                    style="width: 100%; padding: 1.25rem; font-weight: 800; margin-top: 2rem; justify-content: center; border-radius: 1rem;">
                    <i class="fas fa-save" style="margin-right: 0.75rem;"></i> Guardar Cambios
                </button>
            </form>
        </div>
    </div>

    <script>
        function openEditBudgetModal(id, name, amount, startDate, endDate) {
            document.getElementById('editBudgetForm').action = '/budget/edit/' + id;
            document.getElementById('editBudgetName').value = name;
            document.getElementById('editBudgetAmount').value = amount;

            const parseDate = (dateStr) => {
                const d = new Date(dateStr);
                return d.toISOString().split('T')[0];
            };

            document.getElementById('editBudgetStartDate').value = parseDate(startDate);
            document.getElementById('editBudgetEndDate').value = parseDate(endDate);

            document.getElementById('editBudgetModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
            document.body.classList.add('modal-open');
        }

        function closeEditBudgetModal() {
            document.getElementById('editBudgetModal').style.display = 'none';
            document.body.style.overflow = 'auto';
            document.body.classList.remove('modal-open');
        }

        window.onclick = function (event) {
            const modal = document.getElementById('editBudgetModal');
            if (event.target == modal) {
                closeEditBudgetModal();
            }
        }
    </script>
</body>

</html>