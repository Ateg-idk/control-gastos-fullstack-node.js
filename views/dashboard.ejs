<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Gastos Moni</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <div class="container" style="display: flex; min-height: 100vh;">
        <%- include('partials/sidebar', { activePage: 'dashboard' }) %>

            <main class="main-content">
                <header class="top-nav animate-slide-up">
                    <div class="welcome-text">
                        <h1>Hola, <%= username %> 👋</h1>
                        <p style="font-weight: 700; color: var(--primary);">
                            <%= periodName %>
                        </p>
                        <p style="font-size: 0.8125rem; color: var(--text-muted);">
                            <%= dateRange %>
                        </p>
                    </div>
                    <div class="header-actions">
                        <a href="/expenses/add" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Registrar Movimiento
                        </a>
                    </div>
                </header>

                <!-- Financial Health Grid -->
                <div class="stats-grid animate-slide-up">
                    <div class="premium-card" style="border-top: 5px solid var(--primary);">
                        <div class="stat-header">
                            <div class="stat-icon" style="background: var(--primary-light); color: var(--primary);">
                                <i class="fas fa-bullseye"></i>
                            </div>
                            <span class="stat-label">Meta Presupuestada</span>
                        </div>
                        <h2 class="stat-value">S/ <%= budget.toFixed(2) %>
                        </h2>
                        <div
                            style="margin-top: 1.25rem; height: 8px; background: #f1f5f9; border-radius: 99px; overflow: hidden;">
                            <div
                                style="width: <%= Math.min((totalSpent/budget)*100, 100) %>%; height: 100%; background: var(--primary); transition: width 1s ease-out;">
                            </div>
                        </div>
                    </div>

                    <div class="premium-card" style="border-top: 5px solid var(--danger);">
                        <div class="stat-header">
                            <div class="stat-icon" style="background: #fee2e2; color: var(--danger);">
                                <i class="fas fa-arrow-trend-down"></i>
                            </div>
                            <span class="stat-label">Total en Salidas</span>
                        </div>
                        <h2 class="stat-value">S/ <%= totalSpent.toFixed(2) %>
                        </h2>
                        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; font-weight: 600;">
                            <%= expenses.length %> transacciones este mes
                        </p>
                    </div>

                    <div class="premium-card" style="border-top: 5px solid var(--success);">
                        <div class="stat-header">
                            <div class="stat-icon" style="background: #dcfce7; color: var(--success);">
                                <i class="fas fa-wallet"></i>
                            </div>
                            <span class="stat-label">Balance Disponible</span>
                        </div>
                        <h2 class="stat-value" style="color: var(--success);">S/ <%= balance.toFixed(2) %>
                        </h2>
                        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; font-weight: 600;">
                            <%= ((balance/budget)*100).toFixed(0) %>% libre del presupuesto
                        </p>
                    </div>
                </div>                <!-- Global Assets & Loans -->
                <div class="analysis-row animate-slide-up" style="grid-template-columns: 1fr;">
                    <!-- Independent Loan Block -->
                    <div class="premium-card"
                        style="background: #0f172a; color: white; border: none; overflow: hidden; position: relative; max-width: 800px; margin: 0 auto; width: 100%;">
                    <!-- Abstract Background Decoration -->
                    <div
                        style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: rgba(79, 70, 229, 0.1); border-radius: 50%; filter: blur(40px);">
                    </div>

                    <h3
                        style="margin-bottom: 1.75rem; font-weight: 800; display: flex; align-items: center; gap: 0.75rem; color: #94a3b8; position: relative;">
                        <i class="fas fa-piggy-bank" style="color: var(--warning);"></i>
                        Gestión de Préstamos
                    </h3>

                    <div style="margin-bottom: 2.5rem; position: relative;">
                        <span
                            style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: #64748b; font-weight: 800;">Activos
                            por Cobrar</span>
                        <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-top: 0.5rem;">
                            <span style="font-size: 1.25rem; font-weight: 800; color: #94a3b8;">S/</span>
                            <h2 style="font-size: 2.75rem; font-weight: 900; color: white; letter-spacing: -0.05em;">
                                <%= loanStats.totalPending.toFixed(2) %>
                            </h2>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr; gap: 1.25rem; position: relative;">
                        <div
                            style="background: rgba(255,255,255,0.03); padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.05);">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-size: 0.75rem; color: #94a3b8; font-weight: 700;">Total
                                    Recuperado</span>
                                <i class="fas fa-circle-check" style="color: var(--success);"></i>
                            </div>
                            <p style="font-weight: 800; color: white; font-size: 1.25rem; margin-top: 0.25rem;">S/
                                <%= loanStats.totalPaid.toFixed(2) %>
                            </p>
                        </div>

                        <a href="/loans" class="btn"
                            style="background: var(--primary); color: white; width: 100%; border-radius: 1rem; justify-content: center; padding: 1rem; font-size: 0.9rem;">
                            <i class="fas fa-arrow-right-to-bracket"></i> Ir al Centro de Préstamos
                        </a>
                    </div>

                    <div
                        style="margin-top: 2rem; background: rgba(245, 158, 11, 0.1); border-radius: 0.75rem; padding: 0.875rem; font-size: 0.75rem; color: #f59e0b; border-left: 3px solid #f59e0b; line-height: 1.5;">
                        Los préstamos son activos independientes. No afectan el presupuesto de gastos mensual.
                    </div>
                </div>
    </div>

    <!-- Recent Transactions -->
    <div class="premium-card" style="margin-top: 2rem;" class="animate-slide-up">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h3 style="font-weight: 800; display: flex; align-items: center; gap: 0.75rem; font-size: 1.25rem;">
                    <i class="fas fa-receipt" style="color: var(--primary);"></i>
                    Últimas Transacciones
                </h3>
            </div>
            <a href="/expenses" class="btn"
                style="background: var(--bg-alt); color: var(--primary); font-weight: 700; font-size: 0.8rem; border-radius: 0.75rem;">
                Historial Completo <i class="fas fa-arrow-right" style="font-size: 0.75rem; margin-left: 0.25rem;"></i>
            </a>
        </div>

        <div class="table-container">
            <table class="data-table mobile-cards">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Concepto</th>
                        <th>Categoría</th>
                        <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    <% expenses.slice(0, 5).forEach(expense=> { %>
                        <tr>
                            <td data-label="Fecha"
                                style="color: var(--text-muted); font-size: 0.85rem; font-weight: 600;">
                                <%= new Date(expense.date).toLocaleDateString('es-ES', { day: '2-digit' , month: 'short'
                                    }) %>
                            </td>
                            <td data-label="Concepto">
                                <div style="font-weight: 700; color: var(--text-main);">
                                    <%= expense.name %>
                                </div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">
                                    <%= expense.description || 'Gasto registrado' %>
                                </div>
                            </td>
                            <td data-label="Categoría">
                                <span
                                    style="font-size: 0.65rem; font-weight: 800; background: var(--primary-light); color: var(--primary); padding: 0.35rem 0.85rem; border-radius: 2rem; text-transform: uppercase; letter-spacing: 0.05em;">
                                    <%= expense.category || 'Otros' %>
                                </span>
                            </td>
                            <td data-label="Monto" style="font-weight: 800; color: <%= expense.amount < 0 ? 'var(--success)' : 'var(--danger)' %>; font-size: 1rem;">
                                <%= expense.amount < 0 ? '+ S/' : '- S/' %> <%= Math.abs(parseFloat(expense.amount)).toFixed(2) %>
                            </td>
                        </tr>
                        <% }) %>
                            <% if (expenses.length===0) { %>
                                <tr>
                                    <td colspan="4" style="text-align: center; padding: 4rem;">
                                        <div style="color: var(--text-muted);">
                                            <i class="fas fa-inbox"
                                                style="font-size: 3rem; opacity: 0.2; display: block; margin-bottom: 1rem;"></i>
                                            No tienes movimientos este mes.
                                        </div>
                                    </td>
                                </tr>
                                <% } %>
                </tbody>
            </table>
        </div>
    </div>
    </main>
    </div>

</body>

</html>