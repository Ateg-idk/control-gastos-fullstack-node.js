<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - GastosMoni</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --surface: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --bg-body: #f8fafc;
            --border: #e2e8f0;
            --danger: #ef4444;
            --success: #22c55e;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: var(--bg-body);
            overflow-x: hidden;
        }

        .split-layout {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Left Side - Visuals */
        .visual-section {
            flex: 1;
            background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 4rem;
            color: white;
            overflow: hidden;
        }

        .visual-content {
            position: relative;
            z-index: 10;
            max-width: 500px;
            text-align: center;
        }

        .visual-title {
            font-size: 3rem;
            font-weight: 900;
            letter-spacing: -0.03em;
            margin-bottom: 1.5rem;
            line-height: 1.1;
        }

        .visual-subtitle {
            font-size: 1.125rem;
            font-weight: 400;
            opacity: 0.9;
            line-height: 1.6;
        }

        .ambient-shape {
            position: absolute;
            background: rgba(255, 255, 255, 0.1);
            filter: blur(80px);
            border-radius: 50%;
            z-index: 1;
        }

        .shape-1 { width: 400px; height: 400px; top: -100px; left: -100px; }
        .shape-2 { width: 500px; height: 500px; bottom: -150px; right: -100px; background: rgba(99, 102, 241, 0.2); }

        /* Right Side - Form */
        .form-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            background: var(--surface);
            position: relative;
            overflow-y: auto;
        }

        .form-container {
            width: 100%;
            max-width: 420px;
            margin: auto 0;
            padding: 2rem 0;
        }

        .form-header {
            margin-bottom: 2.5rem;
        }

        .form-title {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 0.5rem;
            letter-spacing: -0.02em;
        }

        .form-subtitle {
            color: var(--text-muted);
            font-size: 1rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
            position: relative;
        }

        .form-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 1.25rem;
            color: var(--text-muted);
            font-size: 1.1rem;
            transition: color 0.3s ease;
            z-index: 2;
        }

        .form-input {
            width: 100%;
            padding: 0.875rem 1rem 0.875rem 3.25rem;
            border: 2px solid var(--border);
            border-radius: 0.75rem;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
            color: var(--text-main);
            background: var(--surface);
            font-family: inherit;
        }

        .form-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        .form-input:focus ~ .input-icon,
        .form-input:not(:placeholder-shown) ~ .input-icon {
            color: var(--primary);
        }

        .password-toggle {
            position: absolute;
            right: 1.25rem;
            color: var(--text-muted);
            cursor: pointer;
            padding: 0.25rem;
            z-index: 2;
        }

        .password-toggle:hover {
            color: var(--text-main);
        }

        .btn-submit {
            width: 100%;
            background: var(--primary);
            color: white;
            border: none;
            padding: 1rem;
            border-radius: 0.75rem;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            margin-top: 1.5rem;
        }

        .btn-submit:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
        }

        .auth-links {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.95rem;
            color: var(--text-muted);
        }

        .auth-links a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 700;
            transition: color 0.3s;
        }

        .auth-links a:hover {
            text-decoration: underline;
        }

        .error-alerta, .success-alerta {
            padding: 1rem;
            border-radius: 0.5rem;
            margin-bottom: 2rem;
            font-size: 0.9rem;
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            animation: slideDown 0.3s ease-out forwards;
        }

        .error-alerta { border-left: 4px solid var(--danger); background: #fef2f2; color: #991b1b; }
        .success-alerta { border-left: 4px solid var(--success); background: #f0fdf4; color: #166534; }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo-icon {
            width: 64px;
            height: 64px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255,255,255,0.2);
            transform: rotate(10deg);
        }

        /* Mobile Responsive */
        @media (max-width: 900px) {
            .visual-section { 
                position: fixed;
                inset: 0;
                width: 100%;
                height: 100%;
                padding: 1rem;
                z-index: 1;
            }
            .visual-content {
                display: none;
            }
            .form-section { 
                position: relative;
                z-index: 10;
                background: transparent;
                width: 100%;
                min-height: 100vh;
            }
            .form-container {
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(16px);
                border: 1px solid rgba(255, 255, 255, 0.4);
                padding: 2.5rem;
                border-radius: 2rem;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            }
            .shape-1 { width: 300px; height: 300px; top: -50px; left: -50px; }
            .shape-2 { width: 400px; height: 400px; bottom: -100px; right: -50px; }
        }
        @media (max-width: 480px) {
            .form-container { padding: 1.5rem; }
            .form-title { font-size: 1.75rem; }
        }
    </style>
</head>

<body>
    <div class="split-layout">
        <!-- Lado Visual (Izquierdo) -->
        <div class="visual-section">
            <div class="ambient-shape shape-1"></div>
            <div class="ambient-shape shape-2"></div>
            <div class="visual-content">
                <div class="logo-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h1 class="visual-title">Unirse a<br>GastosMoni</h1>
                <p class="visual-subtitle">El primer paso نحو una mejor salud financiera comienza aquí. Únete hoy.</p>
            </div>
        </div>

        <!-- Lado Formulario (Derecho) -->
        <div class="form-section">
            <div class="form-container">
                <div class="form-header">
                    <h2 class="form-title">Crear Cuenta</h2>
                    <p class="form-subtitle">Completa tus datos para solicitar acceso.</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-alerta">
                        <i class="fas fa-exclamation-circle" style="margin-top: 2px;"></i>
                        <div><%= error %></div>
                    </div>
                <% } %>
                
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="success-alerta">
                        <i class="fas fa-check-circle" style="margin-top: 2px;"></i>
                        <div><%= success %></div>
                    </div>
                <% } %>

                <form action="/register" method="POST">
                    <div class="form-group">
                        <label class="form-label" for="username">Usuario</label>
                        <div class="input-wrapper">
                            <input type="text" id="username" name="username" class="form-input" required placeholder="Cómo quieres llamarte">
                            <i class="fas fa-id-card input-icon"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="email">Correo Electrónico</label>
                        <div class="input-wrapper">
                            <input type="email" id="email" name="email" class="form-input" required placeholder="tu@correo.com">
                            <i class="fas fa-envelope input-icon"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="phone">Número de Celular</label>
                        <div class="input-wrapper">
                            <input type="tel" id="phone" name="phone" class="form-input" required pattern="[0-9]{9}" maxlength="9" minlength="9" title="Debe contener exactamente 9 dígitos numéricos" placeholder="Ej. 987654321">
                            <i class="fas fa-phone input-icon"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="password">Contraseña</label>
                        <div class="input-wrapper">
                            <input type="password" id="password" name="password" class="form-input" required placeholder="••••••••">
                            <i class="fas fa-lock input-icon"></i>
                            <i class="fas fa-eye password-toggle" id="togglePassword"></i>
                        </div>
                    </div>

                    <button type="submit" class="btn-submit">
                        Crear Cuenta <i class="fas fa-bolt"></i>
                    </button>
                </form>

                <div class="auth-links">
                    ¿Ya eres miembro? <a href="/login">Inicia sesión ahora</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#password');

        togglePassword.addEventListener('click', function () {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);
            this.classList.toggle('fa-eye-slash');
        });
    </script>
</body>
</html>